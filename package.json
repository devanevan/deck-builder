{
  "name": "deck-builder",
  "private": true,
  "scripts": {
    "start": "pnpm --filter @deck-builder/app start",
    "web": "pnpm --filter @deck-builder/app web",
    "android": "pnpm --filter @deck-builder/app android",
    "ios": "pnpm --filter @deck-builder/app ios",
    "export:web": "pnpm --filter @deck-builder/app export:web",
    "build:functions": "pnpm --filter @deck-builder/functions build",
    "deploy:functions": "pnpm --filter @deck-builder/functions sls:deploy",
    "dev:functions": "pnpm --filter @deck-builder/functions offline",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "typescript": "^5.3.3"
  }
}
